<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat datang kembali"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_bold"
            android:textColor="#333"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Masuk untuk melanjutkan"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="#777"
            android:layout_marginBottom="16dp"/>

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:fontFamily="@font/poppins_medium"/>

        <EditText
            android:id="@+id/etLoginEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="emailmu@gmail.com"
            android:inputType="textEmailAddress"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginBottom="12dp"/>

        <!-- Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:fontFamily="@font/poppins_medium"/>

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Password"
            android:inputType="textPassword"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginBottom="12dp"/>

        <!-- Lupa Password -->
        <TextView
            android:id="@+id/txtLupaPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lupa Password ?"
            android:textColor="#5B7FFF"
            android:fontFamily="@font/poppins_medium"
            android:layout_gravity="end"
            android:layout_marginBottom="20dp"/>

        <!-- Button Login -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="MASUK"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="#AFC3F2"
            android:layout_marginBottom="12dp"/>

        <!-- atau -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="atau lanjut dengan"
            android:gravity="center"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginBottom="12dp"/>

        <!-- Google -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="CONTINUE WITH GOOGLE"
            android:textColor="#5B7FFF"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="@android:color/transparent"
            app:strokeColor="#5B7FFF"
            app:strokeWidth="2dp"
            app:cornerRadius="25dp"
            android:layout_marginBottom="12dp"/>

        <!-- Facebook -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFacebook"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="CONTINUE WITH FACEBOOK"
            android:textColor="#5B7FFF"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="@android:color/transparent"
            app:strokeColor="#5B7FFF"
            app:strokeWidth="2dp"
            app:cornerRadius="25dp"
            android:layout_marginBottom="12dp"/>

        <!-- Apple -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApple"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="CONTINUE WITH APPLE"
            android:textColor="#5B7FFF"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="@android:color/transparent"
            app:strokeColor="#5B7FFF"
            app:strokeWidth="2dp"
            app:cornerRadius="25dp"
            android:layout_marginBottom="16dp"/>

        <!-- Link ke Signup -->
        <TextView
            android:id="@+id/txtDaftar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belum punya akun? Daftar"
            android:textColor="#5B7FFF"
            android:fontFamily="@font/poppins_medium"
            android:layout_gravity="center"/>

    </LinearLayout>
</ScrollView>