<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA">

    <!-- SCROLLABLE CONTENT -->
    <ScrollView 
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- FOTO -->
            <ImageView
                android:id="@+id/iv_detail_foto"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:scaleType="centerCrop"
                tools:src="@android:drawable/ic_menu_gallery"
                android:background="#E0E0E0"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- NAMA BARANG -->
                <TextView
                    android:id="@+id/tv_detail_nama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="DOMPET BALENCIAGA"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="16dp"/>
                
                <!-- KATEGORI -->
                <TextView
                    android:id="@+id/tv_detail_kategori"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Kategori: Barang Pribadi"
                    android:textSize="14sp"
                    android:textColor="#5B7FFF"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/outline_button"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"/>

                <!-- TANGGAL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/calendar_details"
                        app:tint="#5B7FFF"/>
                    <TextView
                        android:id="@+id/tv_detail_tanggal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        tools:text="DITEMUKAN pada: 4/13/2026"
                        android:textColor="#555555"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- LOKASI -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/pin_location"
                        app:tint="#5B7FFF"/>
                    <TextView
                        android:id="@+id/tv_detail_lokasi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        tools:text="Lokasi: Kantin Utama"
                        android:textColor="#555555"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- DESKRIPSI -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deskripsi"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>
                
                <TextView
                    android:id="@+id/tv_detail_deskripsi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Dompet kulit warna hitam. Di dalamnya terdapat beberapa kartu identitas dan sedikit uang tunai. Ditemukan tergeletak di meja kantin."
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"/>

                <!-- KONTAK & UPLOADER INFO (Card) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Informasi Uploader"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"
                            android:layout_marginBottom="12dp"/>

                        <!-- UPLOADER NAME -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/person_details"
                                app:tint="#5B7FFF"/>
                            <TextView
                                android:id="@+id/tv_detail_uploader"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                tools:text="Budi Santoso"
                                android:textColor="#555555"
                                android:textSize="14sp"/>
                        </LinearLayout>

                        <!-- KONTAK/WA -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/phoneicon"
                                app:tint="#5B7FFF"/>
                            <TextView
                                android:id="@+id/tv_detail_kontak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                tools:text="+6281234567890"
                                android:textColor="#5B7FFF"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVBAR -->
    <include layout="@layout/bottom_navbar" />

</LinearLayout>
