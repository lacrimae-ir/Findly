<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DETAIL PREFERENSI\nANDA"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Masukkan informasi tambahan terkait barang yang sering Anda cari (misal: merek, warna, atau model tertentu)."
        android:textSize="14sp"
        android:textColor="#777777"
        android:layout_marginBottom="32dp"
        android:gravity="center" />

    <EditText
        android:id="@+id/etPreferenceDetail"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="Contoh: Saya sering mencari laptop ThinkPad hitam, dompet kulit cokelat, atau gantungan kunci motor..."
        android:gravity="top|start"
        android:padding="16dp"
        android:background="@drawable/bg_edit_text"
        android:inputType="textMultiLine"
        android:textColor="#000000"
        android:textColorHint="#888888"
        android:textSize="16sp"
        android:layout_marginBottom="32dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSimpan"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="SIMPAN"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_survey_button_selected"
        android:layout_marginTop="16dp"
        android:textStyle="bold" />

</LinearLayout>
